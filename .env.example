# ============================================================
# AI Agency Platform — Environment Variables
#
# Copy this file to .env and fill in every value before running.
# The .env file is in .gitignore and must NEVER be committed.
#
# Required variables are marked [REQUIRED].
# Optional variables have sensible defaults and are marked [OPTIONAL].
# ============================================================


# ------------------------------------------------------------
# Anthropic Claude API
# Get your key at: https://console.anthropic.com/
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...                         # [REQUIRED]


# ------------------------------------------------------------
# Supabase
# Project URL + service role key: Supabase dashboard → Settings → API
#
# WARNING: The service_role key has full database access and bypasses
# Row Level Security. Never expose it in frontend code or public repos.
# ------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co      # [REQUIRED]
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...  # [REQUIRED] — KEEP SECRET


# ------------------------------------------------------------
# Twilio — WhatsApp Integration
# Leave blank until you are ready to connect WhatsApp.
# Twilio console: https://console.twilio.com/
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx      # [OPTIONAL]
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx         # [OPTIONAL]
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886               # [OPTIONAL] Twilio sandbox number


# ------------------------------------------------------------
# Currency Conversion
# Used to convert USD API costs → ZAR for client billing display.
# Update this monthly or connect a live rate API later.
# Current approximate rate as of early 2026: ~18.50
# ------------------------------------------------------------
USD_ZAR_EXCHANGE_RATE=18.50                                # [OPTIONAL — defaults to 18.50]


# ------------------------------------------------------------
# Dashboard CORS
# The Vercel URL of your admin dashboard frontend.
# Used by the backend to allow cross-origin requests from the dashboard.
# Example: https://ai-agency-dashboard.vercel.app
# ------------------------------------------------------------
DASHBOARD_ORIGIN=https://your-dashboard.vercel.app        # [OPTIONAL — add when deploying]


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
ENVIRONMENT=development                                     # [OPTIONAL] development | production
LOG_LEVEL=INFO                                             # [OPTIONAL] DEBUG | INFO | WARNING | ERROR
