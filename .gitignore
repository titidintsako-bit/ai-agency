# ============================================================
# AI Agency Platform — Git Ignore Rules
# ============================================================

# --- Secrets (CRITICAL — never commit these) ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
venv/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- Node / Dashboard ---
node_modules/
.next/
dist/
.cache/

# --- Deployment ---
.vercel/
.railway/

# --- Supabase CLI temp files ---
supabase/.temp/
.supabase/
